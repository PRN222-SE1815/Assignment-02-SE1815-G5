@page
@model Presentation.Areas.Teacher.Pages.Quiz.IndexModel
@{
    ViewBag.Title = "Create Quiz";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Teacher/quiz.css" asp-append-version="true" />
}

<div class="quiz-container">
    <div class="quiz-header">
        <h1><i class="fas fa-plus-circle"></i> Create New Quiz</h1>
    </div>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success">
            <i class="fas fa-check-circle"></i> @Model.SuccessMessage
            @if (Model.CreatedQuiz != null)
            {
                <div class="mt-2">
                    <a asp-area="Teacher" asp-page="/Quiz/Questions" asp-route-quizId="@Model.CreatedQuiz.QuizId"
                       class="btn btn-primary btn-sm">
                        <i class="fas fa-plus"></i> Add Questions
                    </a>
                    <a asp-area="Teacher" asp-page="/Quiz/Manage" asp-route-quizId="@Model.CreatedQuiz.QuizId"
                       class="btn btn-secondary btn-sm">
                        <i class="fas fa-cog"></i> Manage Quiz
                    </a>
                </div>
            }
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger">
            <i class="fas fa-exclamation-circle"></i> @Model.ErrorMessage
        </div>
    }

    <div class="form-card">
        <form method="post" asp-page-handler="Create">
            <div class="form-group">
                <label asp-for="CreateRequest.ClassSectionId" class="form-label">Class Section *</label>
                <select asp-for="CreateRequest.ClassSectionId" class="form-input" required id="classSectionSelect">
                    <option value="">-- Select a Class Section --</option>
                    @foreach (var cls in Model.TeacherClasses)
                    {
                        if (Model.ClassSectionId == cls.ClassSectionId)
                        {
                            <option value="@cls.ClassSectionId" selected>@cls.CourseCode - @cls.SectionCode</option>
                        }
                        else
                        {
                            <option value="@cls.ClassSectionId">@cls.CourseCode - @cls.SectionCode</option>
                        }
                    }
                </select>
                <span asp-validation-for="CreateRequest.ClassSectionId" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="CreateRequest.QuizTitle" class="form-label">Quiz Title *</label>
                <input asp-for="CreateRequest.QuizTitle" class="form-input" maxlength="200"
                       placeholder="e.g. Midterm Quiz - Chapter 1-5" required />
                <span asp-validation-for="CreateRequest.QuizTitle" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="CreateRequest.Description" class="form-label">Description</label>
                <textarea asp-for="CreateRequest.Description" class="form-input" rows="3"
                          placeholder="Optional description..."></textarea>
            </div>

            <div class="form-group" id="gradeItemGroup" style="display:none;">
                <label class="form-label">
                    <i class="fas fa-book"></i> Link to Grade Column (optional)
                </label>
                <select name="CreateRequest.GradeItemId" id="gradeItemSelect" class="form-input">
                    <option value="">-- No grade sync --</option>
                </select>
                <span class="form-hint">When linked, student scores will auto-fill into this grade column after quiz grading.</span>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="CreateRequest.TotalQuestions" class="form-label">Total Questions *</label>
                    <select asp-for="CreateRequest.TotalQuestions" class="form-input" required>
                        <option value="10">10 Questions</option>
                        <option value="20">20 Questions</option>
                        <option value="30">30 Questions</option>
                    </select>
                    <span asp-validation-for="CreateRequest.TotalQuestions" class="field-validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="CreateRequest.TimeLimitMin" class="form-label">Time Limit (minutes)</label>
                    <input asp-for="CreateRequest.TimeLimitMin" class="form-input" type="number" min="1" max="480"
                           placeholder="Optional" />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="CreateRequest.StartAt" class="form-label">Start At (UTC)</label>
                    <input asp-for="CreateRequest.StartAt" class="form-input" type="datetime-local" />
                </div>

                <div class="form-group">
                    <label asp-for="CreateRequest.EndAt" class="form-label">End At (UTC)</label>
                    <input asp-for="CreateRequest.EndAt" class="form-input" type="datetime-local" />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group form-check-group">
                    <label class="form-check-label">
                        <input asp-for="CreateRequest.ShuffleQuestions" type="checkbox" class="form-check-input" />
                        Shuffle Questions
                    </label>
                </div>

                <div class="form-group form-check-group">
                    <label class="form-check-label">
                        <input asp-for="CreateRequest.ShuffleAnswers" type="checkbox" class="form-check-input" />
                        Shuffle Answers
                    </label>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save"></i> Create Draft Quiz
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var classSelect = document.getElementById('classSectionSelect');
            var gradeGroup = document.getElementById('gradeItemGroup');
            var gradeSelect = document.getElementById('gradeItemSelect');

            if (!classSelect) return;

            classSelect.addEventListener('change', function () {
                loadGradeItems(this.value);
            });

            // Load on page init if a class section is already selected
            if (classSelect.value) {
                loadGradeItems(classSelect.value);
            }

            async function loadGradeItems(classSectionId) {
                gradeSelect.innerHTML = '<option value="">-- No grade sync --</option>';
                if (!classSectionId) {
                    gradeGroup.style.display = 'none';
                    return;
                }

                try {
                    var resp = await fetch('?handler=GradeItems&classSectionId=' + classSectionId);
                    var result = await resp.json();

                    if (result.success && result.data && result.data.length > 0) {
                        result.data.forEach(function (item) {
                            var opt = document.createElement('option');
                            opt.value = item.gradeItemId;
                            var label = item.itemName;
                            if (item.weight) label += ' (' + item.weight + ')';
                            opt.textContent = label;
                            gradeSelect.appendChild(opt);
                        });
                        gradeGroup.style.display = '';
                    } else {
                        gradeGroup.style.display = 'none';
                    }
                } catch (e) {
                    gradeGroup.style.display = 'none';
                }
            }
        })();
    </script>
}
